# =============================================================================
# Rust - Generated by Cargo
# =============================================================================
# 编译输出目录
target/
**/target/

# Cargo 生成的锁定文件（对于库项目应该忽略，对于二进制项目应该提交）
# 本项目是二进制项目，但为了方便开发，保留 Cargo.lock
cargo.lock.orig

# =============================================================================
# Rust - 备份和临时文件
# =============================================================================
**/*.rs.bk
**/*.rs.orig
*.pdb
*.exe
*.dll
*.so
*.dylib

# =============================================================================
# IDE 和编辑器
# =============================================================================
# JetBrains (IntelliJ, CLion, RustRover)
.idea/
*.iml
*.iws
*.ipr
out/

# Visual Studio Code
.vscode/
*.code-workspace
.history/

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
\.\#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# Eclipse
.project
.classpath
.settings/

# =============================================================================
# 操作系统
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*
.directory
.Trash-*

# =============================================================================
# 项目特定 - cu-scanner
# =============================================================================
# 日志文件
*.log
/var/log/
/var/

# 运行时生成的输出文件
*.xml
!test/**/*.xml  # 保留测试数据中的 XML
output/
outputs/
results/

# 临时配置文件（包含敏感信息）
config/cu-scanner.local.toml
config/*.local.toml
*.local.toml

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 下载的 CSAF 文件（临时）
downloads/
csaf_files/
*.json.tmp

# 导出的 OVAL 文件
*.oval.xml
oval-definitions.xml

# =============================================================================
# 测试相关
# =============================================================================
# 测试覆盖率输出
tarpaulin-report.html
cobertura.xml
*.profraw
*.profdata

# 基准测试结果
benches/results/
criterion/

# =============================================================================
# 文档生成
# =============================================================================
# rustdoc 输出
doc/
docs/html/

# =============================================================================
# 依赖管理工具
# =============================================================================
# cargo-deny 缓存
cargo-deny-cache/

# cargo-outdated
cargo-outdated.toml

# =============================================================================
# 安全/密钥（确保不提交敏感信息）
# =============================================================================
*.pem
*.key
*.crt
*.cert
*.pfx
*.p12
secrets.toml
secrets.json
.env
.env.local
.env.*.local

# =============================================================================
# 其他
# =============================================================================
# 压缩文件
*.tar
*.tar.gz
*.tgz
*.zip
*.rar
*.7z

# 临时目录
tmp/
temp/
.tmp/
